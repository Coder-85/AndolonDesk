                </HBox>

                <HBox spacing="12" styleClass="menu-item">
                    <Label text="👤" />
                    <Label text="Profile" />
                </HBox>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="22" styleClass="main-area">
            <padding>
                <Insets bottom="30" left="40" right="40" top="30" />
