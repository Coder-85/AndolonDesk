                        </padding>
                        <HBox.margin>
                           <Insets bottom="20.0" />
                        </HBox.margin>
                          </VBox>
                  </children>
               </HBox>
               <HBox layoutX="15.0" layoutY="15.0" prefHeight="100.0" prefWidth="200.0">
                  <children>
                     <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="190.0" prefWidth="497.0" styleClass="post-card">
                        <padding>
                           <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                        </padding>
                        <HBox.margin>
                           <Insets bottom="20.0" />
                        </HBox.margin>
                        <children>
                           <Label styleClass="author" text="Sifat Al Islam" />
                           <Label styleClass="date" text="Posted: 12 Jan 2025">
                              <VBox.margin>
