                </HBox>

                <HBox spacing="12" styleClass="menu-item">
                    <Label text="🔍" />
                    <Label text="Search" />
                </HBox>

                <HBox spacing="12" styleClass="menu-item">
                    <Label text="🔖" />
                    <Label text="Bookmarked" />
                </HBox>

                <HBox spacing="12" styleClass="menu-item">
                    <Label text="✉" />
