                              </VBox.margin>
                           </Label>
                           <Label styleClass="title" text="Student Protest for Education Reform" wrapText="true" />
                           <Label styleClass="event" text="Event Date: 20 Feb 2025">
                              <VBox.margin>
                                 <Insets bottom="10.0" />
                              </VBox.margin>
                           </Label>
                           <Label text="Peaceful protest demanding improvements in education policy and campus facilities." wrapText="true">
                              <VBox.margin>
                                 <Insets bottom="10.0" />
                              </VBox.margin>
                           </Label>
                           <Label styleClass="link" text="View Details" />
                        </children>
                     </VBox>
                  </children>
               </HBox>
               <HBox layoutX="15.0" layoutY="244.0" prefHeight="100.0" prefWidth="200.0">
                  <children>
                     <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="190.0" prefWidth="497.0" styleClass="post-card">
                        <padding>
                           <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                        </padding>
                        <HBox.margin>
                           <Insets bottom="20.0" />
                        </HBox.margin>
                        <children>
                           <Label styleClass="author" text="Sifat Al Islam" />
                           <Label styleClass="date" text="Posted: 12 Jan 2025">
                              <VBox.margin>
                                 <Insets bottom="10.0" />
