<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="675.0" prefWidth="900.0" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    <left>
        <VBox prefWidth="232.0" styleClass="sidebar">
            <padding>
                <Insets bottom="25" left="18" right="18" top="25" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="logo-icon">
                    <Label text="A" />
                </StackPane>
                <Label styleClass="logo-text" text="AndolonDesk" />
            </HBox>

            <VBox spacing="6" styleClass="menu-container">
                <HBox spacing="12" styleClass="menu-item active">
                    <Label text="🏠" />
