                    <Label text="Attended" />
                </VBox>

                <VBox alignment="CENTER" style="-fx-background-color: rgb(236, 235, 255);;" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="stat-number" text="12" />
                    <Label text="Upcoming" />
                </VBox>

                <VBox alignment="CENTER" style="-fx-background-color: rgb(255, 244, 229);;" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="stat-number" text="3" />
                    <Label text="Ongoing" />
                </VBox>

                <VBox alignment="CENTER" style="-fx-background-color: rgb(255, 236, 236);;" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="stat-number" text="7" />
